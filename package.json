{
  "name": "aarambha-kits-for-elementor",
  "version": "1.0.0",
  "description": "Aarambha Kits for Elementor plugin packages",
  "main": "Gruntfile.js",
  "scripts": {
    "build": "npm run clean && cross-env NODE_ENV=production webpack --mode production --progress",
    "start": "npm run clean && cross-env NODE_ENV=development webpack --watch --mode development --progress",
    "clean": "rimraf assets/build/*",
    "svg": "svgr -d assets/src/js/icons assets/src/icons",
    "lint:php": "vendor/bin/phpcs",
    "lint:php:fix": "vendor/bin/phpcbf",
    "lint": "eslint assets/src/js/*",
    "lint:fix": "eslint --fix assets/src/js/*",
    "lint-css": "stylelint 'assets/src/sass/**/*.scss'",
    "lint-css:fix": "npm run lint-css -- --fix",
    "package-update": "npx npm-check-updates -u && npm install",
    "precommit": "npm run lint:php && npm run lint-css:fix && npm run lint:fix && npm run build",
    "cypress:open": "cypress open"
  },
  "keywords": [
    "wordpress",
    "themes"
  ],
  "author": "aarambhathemes",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@svgr/cli": "^8.1.0",
    "@wordpress/base-styles": "^8.0.0",
    "@wordpress/block-editor": "^15.19.0",
    "@wordpress/blocks": "^15.19.0",
    "@wordpress/components": "^33.1.0",
    "@wordpress/compose": "^7.46.0",
    "@wordpress/data": "^10.46.0",
    "@wordpress/dependency-extraction-webpack-plugin": "^6.46.0",
    "@wordpress/element": "^6.46.0",
    "@wordpress/eslint-plugin": "^25.2.0",
    "@wordpress/hooks": "^4.46.0",
    "@wordpress/i18n": "^6.19.0",
    "@wordpress/icons": "^13.1.0",
    "@wordpress/server-side-render": "^6.22.0",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^10.1.1",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "cypress": "^15.15.0",
    "eslint": "^10.3.0",
    "eslint-config-wordpress": "^2.0.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-webpack-plugin": "^6.0.0",
    "grunt-checktextdomain": "^1.0.1",
    "grunt-contrib-clean": "^2.0.1",
    "grunt-contrib-compress": "^2.0.0",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-wp-i18n": "^1.0.4",
    "grunt-wp-readme-to-markdown": "^2.1.0",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8",
    "sass-mq": "^7.0.0",
    "style-loader": "^4.0.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-webpack-plugin": "^5.1.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-remove-empty-scripts": "^1.1.1"
  },
  "browserslist": {
    "production": [
      "> 0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "npm-check-updates": "^22.2.0"
  }
}
